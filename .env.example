# ===== Database =====
# Neon PostgreSQL connection string.
# Get yours from https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ===== Admin (optional overrides) =====
# Admin session cookie secret. Set a long random string in production.
# ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# ===== SMTP Email Settings =====
# Details of the SMTP provider (e.g. hostinger, titan, google workspace, etc.)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="info@snack-fruits.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="\"Snack Fruits\" <info@snack-fruits.com>"
SMTP_TO="info@snack-fruits.com"

